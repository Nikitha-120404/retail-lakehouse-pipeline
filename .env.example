# Copy to .env and fill in your values
NEXCART_ENV=local
SPARK_HOME=/usr/local/spark
JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64

# PostgreSQL — Audit Logging (src/utils/audit_logger.py)
# Option A: full DSN (takes priority over individual vars below)
# NEXCART_PG_DSN=postgresql://postgres:password@localhost:5432/nexcart_audit
# Option B: individual vars
NEXCART_PG_HOST=localhost
NEXCART_PG_PORT=5432
NEXCART_PG_DB=nexcart_audit
NEXCART_PG_USER=postgres
NEXCART_PG_PASSWORD=

# Airflow (only needed for orchestration phase)
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////tmp/airflow.db
