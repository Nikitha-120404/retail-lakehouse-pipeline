# airflow.env
# ───────────
# Environment variables for running Airflow locally (pip install, not Docker).
# Load with:  set -a && source airflow/airflow.env && set +a  (Mac/Linux)
#             or copy these into your shell session on Windows.
#
# These are picked up by the DAG to locate your project and Python executable.

# Absolute path to the nexcart-lakehouse project root
# Change this to your actual project path
NEXCART_ROOT=C:\Users\Nithin\Downloads\nexcart-lakehouse-v2\nexcart-lakehouse

# Python executable (use full path if running inside a virtualenv)
# Example: NEXCART_PYTHON=C:\Users\Nithin\AppData\Local\Programs\Python\Python311\python.exe
NEXCART_PYTHON=python

# Airflow home — where Airflow stores its SQLite DB, logs, and config
# Default: ~/airflow  — override here if you want it inside the project
# AIRFLOW_HOME=C:\Users\Nithin\Downloads\nexcart-lakehouse-v2\nexcart-lakehouse\airflow

# Tell Airflow where to find the DAGs
AIRFLOW__CORE__DAGS_FOLDER=C:\Users\Nithin\Downloads\nexcart-lakehouse-v2\nexcart-lakehouse\airflow\dags

# Use SQLite for local dev (zero setup)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///C:/Users/Nithin/airflow/airflow.db

# Use SequentialExecutor with SQLite (simplest local setup)
AIRFLOW__CORE__EXECUTOR=SequentialExecutor

# Don't load the example DAGs
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Pause new DAGs by default (unpause manually from UI or CLI)
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True

# Reduce log noise
AIRFLOW__LOGGING__LOGGING_LEVEL=WARNING
